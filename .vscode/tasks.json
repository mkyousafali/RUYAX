{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "ðŸ“¦ Install Dependencies",
			"type": "shell",
			"command": "pnpm",
			"args": [
				"setup"
			],
			"group": "build",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared"
			},
			"problemMatcher": []
		},
		{
			"label": "ðŸŽ¨ Dev Frontend (npm)",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"dev"
			],
			"options": {
				"cwd": "${workspaceFolder}/frontend"
			},
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared",
				"showReuseMessage": false
			},
			"isBackground": true,
			"problemMatcher": {
				"pattern": {
					"regexp": "^([^\\s].*):(\\d+):(\\d+):\\s+(warning|error):\\s+(.*)$",
					"file": 1,
					"line": 2,
					"column": 3,
					"severity": 4,
					"message": 5
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": ".",
					"endsPattern": "(Local|Network):\\s+http"
				}
			}
		},
		{
			"label": "ðŸŽ¨ Dev Frontend",
			"type": "shell",
			"command": "pnpm",
			"args": [
				"--filter",
				"Ruyax-frontend",
				"dev"
			],
			"group": "build",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared"
			},
			"isBackground": true,
			"problemMatcher": []
		},
